#!/usr/bin/env bash
set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo -e "${YELLOW}[FS] Pre-commit checks...${NC}"

fail() { echo -e "${RED}ERROR: $1${NC}"; exit 1; }

require_tool() {
  if ! cargo "$1" --version &>/dev/null; then
    echo -e "${RED}Tool missing: cargo $1${NC}"
    echo "Install with:"
    echo "  sudo dnf install $2        # Fedora"
    echo "  rustup component add $2    # rustup"
    exit 1
  fi
}

require_tool fmt rustfmt
require_tool clippy clippy

# Format
echo "  [1/3] Format check..."
cargo fmt --all -- --check || fail "Format issues found. Run: cargo fmt --all"

# Clippy — warnings as errors + OOP lints
echo "  [2/3] Clippy..."
RUSTFLAGS="-D warnings" cargo clippy --workspace --all-targets -- \
  -D clippy::large_enum_variant \
  -D clippy::cognitive_complexity \
  -D clippy::too_many_arguments \
  -D clippy::too_many_lines \
  -D clippy::wildcard_imports \
  -D clippy::unused_self \
  || fail "Clippy found issues. Fix them before committing."

# Tests
echo "  [3/3] Tests..."
cargo test --workspace || fail "Tests failed."

echo -e "${GREEN}[FS] All checks passed.${NC}"

